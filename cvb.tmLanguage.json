{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "CVB",
    "scopeName": "source.cvb",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#constants" },
        { "include": "#numbers" },
        { "include": "#operators" },
        { "include": "#functions" }
    ],
    "repository": {
        "comments": {
            "name": "comment.block.cvb",
            "begin": "\\(\\#",
            "end": "\\#\\)"
        },
        "strings": {
            "name": "string.quoted.double.cvb",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.cvb",
                    "match": "\\\\."
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.cvb",
                    "match": "#(import|importf|print|while|for|if|else|def|break)\\b"
                },
                {
                    "name": "keyword.operator.cvb",
                    "match": "\\b(in|and|or|not|TRUE|FALSE)\\b"
                },
                {
                    "name": "keyword.other.cvb",
                    "match": "=>"
                }
            ]
        },
        "types": {
            "name": "support.type.cvb",
            "match": "\\b(str|int|list|dic|math|file|random|net|shell)\\b"
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.boolean.true.cvb",
                    "match": "\\bTRUE\\b"
                },
                {
                    "name": "constant.language.boolean.false.cvb",
                    "match": "\\bFALSE\\b"
                }
            ]
        },
        "numbers": {
            "name": "constant.numeric.cvb",
            "match": "\\b-?\\d+(\\.\\d+)?\\b"
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.arithmetic.cvb",
                    "match": "\\+|\\-|\\*|/|%|\\|\\||&&"
                },
                {
                    "name": "keyword.operator.comparison.cvb",
                    "match": "==|!=|<=|>=|<|>"
                },
                {
                    "name": "keyword.operator.assignment.cvb",
                    "match": "="
                },
                {
                    "name": "keyword.operator.pipe.cvb",
                    "match": "\\|"
                },
                {
                    "name": "keyword.operator.other.cvb",
                    "match": "@|\\$|&|:|;|,|\\.|\\[|\\]|\\{|\\}|\\(|\\)"
                }
            ]
        },
        "functions": {
            "name": "entity.name.function.cvb",
            "match": "#def\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
            "captures": {
                "1": {
                    "name": "entity.name.function.cvb"
                }
            }
        }
    },
    "fileTypes": [
        "cvb"
    ]
}
